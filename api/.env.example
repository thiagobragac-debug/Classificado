##############################################################################
# TAUZE CLASS — Configuração de Ambiente (api/.env.example)
#
# ✅  Este arquivo PODE ser commitado no Git (sem valores reais).
# ⚠️  Copie para "api/.env" e preencha com suas credenciais reais.
#     cp api/.env.example api/.env
##############################################################################


# ═══════════════════════════════════════════════════════════════════════════
# INFRAESTRUTURA
# ═══════════════════════════════════════════════════════════════════════════

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@localhost:6379

MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=your_meilisearch_master_key_here

PORT=3000

# "development" | "production"
NODE_ENV=development

# URL pública do frontend — usada nos redirects de pagamento e no CORS
# Múltiplas origens: separe por vírgula
FRONTEND_URL=http://localhost:8080


# ═══════════════════════════════════════════════════════════════════════════
# GATEWAY ATIVO
# ═══════════════════════════════════════════════════════════════════════════
#
# Define qual gateway será usado pelo sistema.
# Valor deve ser exatamente um de: stripe | mercadopago | pagarme
#
PAYMENT_GATEWAY=stripe


# ═══════════════════════════════════════════════════════════════════════════
# STRIPE
# ═══════════════════════════════════════════════════════════════════════════
#
# Dashboard: https://dashboard.stripe.com/apikeys
# Modo teste → chaves começam com sk_test_ / pk_test_
# Modo live  → chaves começam com sk_live_ / pk_live_
#
# Secret Key — nunca exposta no frontend
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Publishable Key — pode ser exposta no frontend
STRIPE_PUB_KEY=pk_test_your_stripe_publishable_key_here

# Webhook Signing Secret (começa com whsec_...)
# Dashboard → Developers → Webhooks → seu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here


# ═══════════════════════════════════════════════════════════════════════════
# MERCADO PAGO
# ═══════════════════════════════════════════════════════════════════════════
#
# Dashboard: https://www.mercadopago.com.br/developers/panel/app
# → Suas integrações → Selecione o app → Credenciais de produção/teste
#
# Access Token (Secret) — nunca exposto no frontend
MP_ACCESS_TOKEN=your_mercadopago_access_token_here

# Public Key — pode ser exposta no frontend
MP_PUBLIC_KEY=your_mercadopago_public_key_here

# Webhook Secret
MP_WEBHOOK_SECRET=your_mercadopago_webhook_secret_here


# ═══════════════════════════════════════════════════════════════════════════
# PAGAR.ME
# ═══════════════════════════════════════════════════════════════════════════
#
# Dashboard: https://dashboard.pagar.me/
# → Configurações → Chaves de API
#
# Secret Key — nunca exposta no frontend
PAGARME_SECRET_KEY=your_pagarme_secret_key_here

# Public Key — pode ser exposta no frontend
PAGARME_PUB_KEY=your_pagarme_public_key_here

# Webhook Secret
PAGARME_WEBHOOK_SECRET=your_pagarme_webhook_secret_here


# ═══════════════════════════════════════════════════════════════════════════
# WEBHOOK SECRET (Legado — mantido para compatibilidade)
# ═══════════════════════════════════════════════════════════════════════════
#
# Fallback caso as variáveis específicas por gateway não estejam definidas.
#
WEBHOOK_SECRET=whsec_your_legacy_webhook_secret_here
